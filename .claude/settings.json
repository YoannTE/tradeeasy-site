{
  "permissions": {
    "allow": [
      "Bash(npm install *)",
      "Bash(npm run *)",
      "Bash(npx *)",
      "Bash(npx playwright *)",
      "Bash(mkdir *)",
      "Bash(curl *)",
      "Bash(git *)",
      "mcp__stitch__*",
      "mcp__payload__*"
    ],
    "deny": ["Bash(rm -rf *)", "Bash(sudo *)"]
  },
  "env": {
    "CLAUDE_CODE_EXPERIMENTAL_AGENT_TEAMS": "1"
  },
  "statusLine": {
    "type": "command",
    "command": "bash ./statusline-command.sh"
  },
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Write",
        "hooks": [
          {
            "type": "command",
            "command": "npx prettier --write \"$FILEPATH\" 2>/dev/null || true"
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "osascript -e 'display notification \"Agent termine\" with title \"Claude Code\"' 2>/dev/null || true"
          }
        ]
      }
    ]
  },
  "mcpServers": {}
}
