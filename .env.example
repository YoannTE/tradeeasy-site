# Database
DATABASE_URL=

# Payload CMS
PAYLOAD_SECRET=

# Stripe
STRIPE_SECRET_KEY=
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=
STRIPE_WEBHOOK_SECRET=

# Email (Resend)
RESEND_API_KEY=

# App
NEXT_PUBLIC_APP_URL=http://localhost:3000
ADMIN_EMAIL=admin@admin.com

# Cron Jobs
CRON_SECRET=

# Anthropic (Claude) — traduction auto du brief quotidien (EN/ES/DE)
# Obtenir une cle sur https://console.anthropic.com
ANTHROPIC_API_KEY=

# Analytics (PostHog - optional)
NEXT_PUBLIC_POSTHOG_KEY=
NEXT_PUBLIC_POSTHOG_HOST=https://app.posthog.com

# Telegram (optional) — notifications instantanees sur ton telephone
# quand un client paye et doit recevoir l'acces TradingView.
# 1. Creer un bot avec @BotFather sur Telegram, copier le token.
# 2. Ecrire au bot une premiere fois pour qu'il puisse t'envoyer des messages.
# 3. Recuperer le chat id via https://api.telegram.org/bot<TOKEN>/getUpdates
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# TradingView — URL directe de la page de gestion d'acces de ton script invite-only.
# Utilisee dans les emails et Telegram pour un acces en 1 clic a la page TradingView.
TRADINGVIEW_SCRIPT_MANAGE_URL=
